      "기운(?:이|은|도)?\\s*(?:없어요|없어|없습니다)"
    ],
    "dizziness": [
      "(?:머리(?:가|는|도)?\\s*)?(?:어지러워요|어지러움|어지러워|어지럽습니다|어질어질해요|어질어질)"
    ],
    "leg_edema": [
      "다리(?:가|는|도)?\\s*(?:붓(?:기|기가)?|부어오릅니다|부었어요|부어)",
      "다리\\s*부기"
    ],
    "myalgia": [
      "(?:온몸|삭신)(?:이|은|도)?\\s*(?:쑤십니다|쑤셔요|쑤시고|결립니다|결려요)",
      "몸살(?:이)?\\s*(?:난\\s*)?것\\s*같"
