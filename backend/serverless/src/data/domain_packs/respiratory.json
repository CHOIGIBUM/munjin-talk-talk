      "콜록(?:거려요|거립니다|해요)"
    ],
    "fever": [
      "(?:열|발열)(?:이|은|도)?\\s*(?:나요|있어요|나는 것 같아요)"
    ],
    "sputum": [
      "가래(?:가|는|도)?\\s*(?:나요|나와요|있어요|껴요)"
    ],
    "chest_discomfort": [
      "가(?:슴|심)(?:이|은|도)?\\s*(?:답답(?:하고|해요|합니다|하다|허고|허다)?)"
