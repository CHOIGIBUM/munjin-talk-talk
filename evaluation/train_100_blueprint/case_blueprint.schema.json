{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Train 100 Case Blueprint Row",
  "type": "object",
  "required": [
    "case_id",
    "visit_type",
    "question_id",
    "question_type",
    "dialect_type",
    "dialect_intensity",
    "symptom_group",
    "gold_symptoms",
    "negative_symptoms",
    "status_pattern",
    "expression_policy",
    "difficulty",
    "renderer_notes"
  ],
  "additionalProperties": false,
  "properties": {
    "case_id": { "type": "string", "pattern": "^train_bp_[0-9]{3}$" },
    "visit_type": { "enum": ["초진", "재진"] },
    "question_id": { "enum": ["Q1", "Q3"] },
    "question_type": { "enum": ["chief_complaint", "new_symptoms"] },
    "dialect_type": { "enum": ["standard", "kangwon"] },
    "dialect_intensity": { "enum": ["none", "light", "medium", "strong"] },
    "symptom_group": {
      "enum": [
        "upper_airway_common",
        "cough_sputum_lower_airway",
        "dyspnea_chest_redflag",
        "systemic_course",
        "ent_swallow_voice_eye",
        "cardio_edema_neuro",
        "gi_abdomen_med_context"
      ]
    },
    "gold_symptoms": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "negative_symptoms": {
      "type": "array",
      "items": { "type": "string" }
    },
    "status_pattern": {
      "enum": [
        "active_current",
        "new_after_followup",
        "persistent_after_followup",
        "worsened_after_followup",
        "denied_negative_context",
        "mixed_resolved_plus_active"
      ]
    },
    "expression_policy": {
      "enum": ["direct_allowed", "lay_preferred", "direct_label_forbidden"]
    },
    "difficulty": { "enum": ["easy", "medium", "hard"] },
    "renderer_notes": { "type": "string" }
  }
}
