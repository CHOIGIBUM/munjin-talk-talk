{
  "version": "test-1000-blueprint-v1",
  "purpose": "Held-out synthetic evaluation set for measuring generalization of train_100-derived runtime artifacts.",
  "generation_mode": "blueprint_first_llm_rendered_text",
  "case_count": 1000,
  "held_out_policy": {
    "may_update_train_artifacts_before_first_eval": false,
    "may_inspect_test_failures_before_first_eval_report": false,
    "may_use_test_cases_as_fewshots": false,
    "may_use_test_cases_as_alias_source": false,
    "first_eval_report_required_before_iteration": true
  },
  "question_distribution": {
    "initial_Q1_chief_complaint": 500,
    "followup_Q3_new_symptoms_or_course": 500
  },
  "language_distribution": {
    "standard_colloquial": 500,
    "kangwon_colloquial": 500
  },
  "quadrants": {
    "initial_Q1_standard": 250,
    "initial_Q1_kangwon": 250,
    "followup_Q3_standard": 250,
    "followup_Q3_kangwon": 250
  },
  "kangwon_intensity_distribution": {
    "light": 300,
    "medium": 150,
    "strong": 50
  },
  "symptom_group_distribution": {
    "upper_airway_common": 220,
    "cough_sputum_lower_airway": 180,
    "dyspnea_chest_redflag": 160,
    "systemic_course": 140,
    "cardio_edema_neuro": 120,
    "ent_swallow_voice_eye": 100,
    "gi_abdomen_med_context": 80
  },
  "question_status_distribution": {
    "initial_Q1": {
      "active_current": 280,
      "denied_negative_context": 160,
      "mixed_resolved_plus_active": 60
    },
    "followup_Q3": {
      "new_after_followup": 250,
      "persistent_after_followup": 100,
      "worsened_after_followup": 70,
      "denied_negative_context": 50,
      "mixed_resolved_plus_active": 30
    }
  },
  "gold_symptom_count_distribution": {
    "one_gold_symptom": 620,
    "two_gold_symptoms": 300,
    "three_gold_symptoms": 80
  },
  "negative_symptom_count_distribution": {
    "no_negative_symptom": 700,
    "one_negative_symptom": 260,
    "two_negative_symptoms": 40
  },
  "expression_policy_distribution": {
    "direct_allowed": 200,
    "lay_preferred": 400,
    "direct_label_forbidden": 400
  },
  "difficulty_distribution": {
    "easy": 300,
    "medium": 450,
    "hard": 250
  },
  "direct_expression_policy": {
    "basic_words_may_be_direct": ["기침", "가래", "콧물", "코막힘", "열", "재채기", "구토", "설사"],
    "complex_labels_should_be_paraphrased": [
      "호흡곤란",
      "운동 시 호흡곤란",
      "흉통",
      "객혈",
      "화농성 객담",
      "검은색 가래",
      "거품이 섞인 가래",
      "삼키기 곤란",
      "가슴 두근거림",
      "부정맥",
      "근력 약화",
      "식욕부진"
    ],
    "max_exact_standard_label_rate": 0.15
  },
  "surface_variation_targets": {
    "short_single_clause": 260,
    "two_clause_with_reason_or_timing": 360,
    "mixed_active_and_denied": 240,
    "followup_course_sentence": 140
  },
  "leakage_rules": {
    "copy_train_100_text": "forbidden",
    "copy_train_100_renderer_notes": "forbidden",
    "patient_text_written_in_blueprint": "forbidden",
    "exact_standard_label_for_direct_label_forbidden": "forbidden",
    "formal_emr_style": "forbidden",
    "q2_or_q4_content": "forbidden",
    "post_eval_training_before_first_report": "forbidden"
  }
}
